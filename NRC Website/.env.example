# Copy this file to .env.local (for local dev) and fill in the real value.
# .env.local is gitignored -- never commit the real endpoint value alongside
# secrets, even though the Apps Script URL itself is not a private credential.
#
# For a production build, this same variable must be present in whatever
# environment runs `npm run build` (host build-env settings, or a
# .env.production file created at build time) -- Vite bakes VITE_* values
# into the static output at build time, not at runtime.

VITE_DISCOVERY_FORM_ENDPOINT=
