/**
 * NRC Discovery Call form backend.
 *
 * Deploy as a Web App (Deploy > New deployment > Web app):
 *   - Execute as: Me
 *   - Who has access: Anyone
 *
 * See ../docs/discovery-form-setup.md for full setup and deployment steps.
 */

// ── CONFIG ──────────────────────────────────────────────────────────
// Every value that identifies *where data goes* or *who gets emailed*
// lives here, in one place.
var CONFIG = {
  SPREADSHEET_ID: '18wgXW4Lt0W50L-SiRREFvTIxHJQaNjPWPqhL8evdZBQ',
  SHEET_NAME: 'NRC Discovery Call Leads',
  INTERNAL_NOTIFY_EMAIL: 'nrbrandculture@gmail.com',
  SENDER_DISPLAY_NAME: 'Team NRC',
  TIMEZONE: 'Asia/Kolkata',
  DEFAULT_SOURCE: 'NRC Website',
  DEFAULT_STATUS: 'New',
  DUPLICATE_WINDOW_SECONDS: 600, // ~10 minutes
  MAX_FIELD_LENGTHS: {
    first_name: 100,
    last_name: 100,
    email: 200,
    brand: 150,
    website: 200,
    service: 100,
    brief: 4000
  }
};

// Customer-confirmation email logo: a 400x278 (2x retina for a 200px
// display width) transparent PNG derivative of the official NRC logo,
// downsampled from the same source already used on the website
// (assets/nrc-logo-2026-transparent.png), embedded as a CID inline
// image -- see sendCustomerConfirmationEmail() for why CID was chosen
// over a hosted URL.
var EMAIL_LOGO_BASE64 = '';

// Exact column order for the sheet header row. This is the single
// source of truth both for writing new rows and for verifying/repairing
// the header row on first run.
var COLUMNS = [
  'Submitted At',
  'First Name',
  'Last Name',
  'Email Address',
  'Brand / Company',
  'Website or Instagram',
  'Service Interested In',
  'Tell Us About Your Brand',
  'Source',
  'Status'
];

var ALLOWED_SERVICES = [
  'Brand Strategy',
  'Brand Identity',
  'Content & Campaigns',
  'Website & Digital Experience',
  'Growth & Performance',
  'Full Brand Package'
];

// ── ENTRY POINT ─────────────────────────────────────────────────────

function doPost(e) {
  try {
    var parsed = parseAndValidatePayload(e);
    if (!parsed.ok) {
      return jsonResponse({
        ok: false,
        code: 'VALIDATION_ERROR',
        message: parsed.message,
        sheetSaved: false,
        customerEmailSent: false,
        internalEmailSent: false
      });
    }

    var data = parsed.data;
    var fingerprint = buildFingerprint(data);
    var cache = CacheService.getScriptCache();

    // Fast path: identical submission already handled recently -- return
    // the exact same response without touching the sheet or sending mail.
    var cached = cache.get(fingerprint);
    if (cached) {
      return jsonResponse(JSON.parse(cached));
    }

    // Serialize the check-then-write sequence across concurrent requests
    // so two near-simultaneous identical submissions can't both slip past
    // the cache check above and double-write.
    var lock = LockService.getScriptLock();
    var gotLock = lock.tryLock(10000);
    if (!gotLock) {
      return jsonResponse({
        ok: false,
        code: 'BUSY',
        message: 'The request could not be processed. Please try again in a moment.',
        sheetSaved: false,
        customerEmailSent: false,
        internalEmailSent: false
      });
    }

    try {
      // Re-check inside the lock in case another request just finished
      // writing this exact fingerprint while we were waiting.
      cached = cache.get(fingerprint);
      if (cached) {
        return jsonResponse(JSON.parse(cached));
      }

      var timestamp = Utilities.formatDate(new Date(), CONFIG.TIMEZONE, 'yyyy-MM-dd HH:mm:ss');
      var sheet = getOrCreateSheet();
      appendRow(sheet, data, timestamp);

      // From here on, the record is saved. A failure sending either email
      // must never be reported as a full failure to the visitor, and must
      // never look like the sheet write itself failed.
      var customerEmailSent = false;
      var internalEmailSent = false;

      var customerEmailError = null;
      var internalEmailError = null;

      try {
        sendCustomerConfirmationEmail(data);
        customerEmailSent = true;
      } catch (emailErr) {
        customerEmailError = String(emailErr);
        console.error('Customer confirmation email failed: ' + customerEmailError);
      }

      try {
        sendInternalNotificationEmail(data, timestamp);
        internalEmailSent = true;
      } catch (emailErr) {
        internalEmailError = String(emailErr);
        console.error('Internal notification email failed: ' + internalEmailError);
      }

      var response = {
        ok: true,
        code: 'SUCCESS',
        message: 'Submission saved.',
        sheetSaved: true,
        customerEmailSent: customerEmailSent,
        internalEmailSent: internalEmailSent,
        // Only present when the corresponding send failed -- lets the
        // frontend log something actionable without ever surfacing it
        // to the visitor.
        customerEmailError: customerEmailError,
        internalEmailError: internalEmailError
      };

      // Only cache (and thus only dedupe) once the record is actually
      // saved -- a failed sheet write must never poison the cache and
      // block a legitimate retry.
      cache.put(fingerprint, JSON.stringify(response), CONFIG.DUPLICATE_WINDOW_SECONDS);

      return jsonResponse(response);
    } catch (writeErr) {
      console.error('Sheet write failed: ' + writeErr);
      return jsonResponse({
        ok: false,
        code: 'SAVE_FAILED',
        message: 'The request could not be saved. Please try again.',
        sheetSaved: false,
        customerEmailSent: false,
        internalEmailSent: false
      });
    } finally {
      lock.releaseLock();
    }
  } catch (err) {
    console.error('Unhandled error in doPost: ' + err);
    return jsonResponse({
      ok: false,
      code: 'INTERNAL_ERROR',
      message: 'Something went wrong. Please try again.',
      sheetSaved: false,
      customerEmailSent: false,
      internalEmailSent: false
    });
  }
}

// Not used by the website (browsers cannot read a cross-origin GET
// response from this endpoint without CORS headers, which Apps Script
// does not attach to doGet). Kept only as a manual health check you can
// open directly in a browser address bar during setup.
function doGet(e) {
  return jsonResponse({ ok: true, message: 'NRC discovery form endpoint is running.' });
}

// ── VALIDATION / SANITIZATION ───────────────────────────────────────
// The frontend already validates before submitting, but nothing here
// trusts that. Every rule is re-applied against the raw payload.

function parseAndValidatePayload(e) {
  if (!e || !e.postData || !e.postData.contents) {
    return { ok: false, message: 'Missing request body.' };
  }

  var raw;
  try {
    raw = JSON.parse(e.postData.contents);
  } catch (parseErr) {
    return { ok: false, message: 'Malformed request body.' };
  }

  if (!raw || typeof raw !== 'object') {
    return { ok: false, message: 'Malformed request body.' };
  }

  // Honeypot: a real visitor never fills this hidden field. Silently
  // reject rather than explaining why -- no need to tip off bots.
  if (raw.company_website && String(raw.company_website).trim() !== '') {
    return { ok: false, message: 'Submission rejected.' };
  }

  // Reject payloads carrying fields we don't expect, rather than
  // silently ignoring them -- keeps the accepted surface area explicit.
  var expectedKeys = ['first_name', 'last_name', 'email', 'brand', 'website', 'service', 'brief', 'company_website'];
  for (var key in raw) {
    if (raw.hasOwnProperty(key) && expectedKeys.indexOf(key) === -1) {
      return { ok: false, message: 'Unexpected field: ' + key };
    }
  }

  function clean(value, maxLength) {
    var str = (value === undefined || value === null) ? '' : String(value);
    str = str.trim();
    if (maxLength && str.length > maxLength) {
      str = str.substring(0, maxLength);
    }
    return str;
  }

  var data = {
    first_name: clean(raw.first_name, CONFIG.MAX_FIELD_LENGTHS.first_name),
    last_name: clean(raw.last_name, CONFIG.MAX_FIELD_LENGTHS.last_name),
    email: clean(raw.email, CONFIG.MAX_FIELD_LENGTHS.email),
    brand: clean(raw.brand, CONFIG.MAX_FIELD_LENGTHS.brand),
    website: clean(raw.website, CONFIG.MAX_FIELD_LENGTHS.website),
    service: clean(raw.service, CONFIG.MAX_FIELD_LENGTHS.service),
    brief: clean(raw.brief, CONFIG.MAX_FIELD_LENGTHS.brief)
  };

  if (!data.first_name) return { ok: false, message: 'First name is required.' };
  if (!data.last_name) return { ok: false, message: 'Last name is required.' };

  var emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!data.email || !emailRe.test(data.email)) {
    return { ok: false, message: 'A valid email address is required.' };
  }

  if (!data.brand) return { ok: false, message: 'Brand / company is required.' };

  if (!data.service || ALLOWED_SERVICES.indexOf(data.service) === -1) {
    return { ok: false, message: 'A valid service selection is required.' };
  }

  if (!data.brief || data.brief.length < 15) {
    return { ok: false, message: 'Please share a bit more about your brand.' };
  }

  // Website/Instagram stays optional -- no presence check.

  return { ok: true, data: data };
}

function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// ── DUPLICATE FINGERPRINT ───────────────────────────────────────────
// Deliberately excludes first/last name: two people submitting the same
// enquiry for the same brand/email within the window should still only
// count once, and name typos/casing shouldn't defeat the dedup check.

function buildFingerprint(data) {
  var normalized = [
    data.email.trim().toLowerCase(),
    data.brand.trim().toLowerCase(),
    data.website.trim().toLowerCase(),
    data.service.trim().toLowerCase(),
    data.brief.trim().toLowerCase()
  ].join('|');

  var digest = Utilities.computeDigest(Utilities.DigestAlgorithm.MD5, normalized, Utilities.Charset.UTF_8);
  var hex = digest.map(function (byte) {
    var v = (byte < 0 ? byte + 256 : byte).toString(16);
    return v.length === 1 ? '0' + v : v;
  }).join('');
  return 'nrc_discovery_' + hex;
}

// ── SHEET ────────────────────────────────────────────────────────────

function getOrCreateSheet() {
  var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
  var sheet = ss.getSheetByName(CONFIG.SHEET_NAME);
  if (!sheet) {
    sheet = ss.insertSheet(CONFIG.SHEET_NAME);
  }

  var lastCol = Math.max(sheet.getLastColumn(), COLUMNS.length);
  var headerRange = sheet.getRange(1, 1, 1, COLUMNS.length);
  var currentHeader = headerRange.getValues()[0];
  var headerMatches = COLUMNS.every(function (col, i) { return currentHeader[i] === col; });
  if (!headerMatches) {
    headerRange.setValues([COLUMNS]);
  }

  return sheet;
}

function appendRow(sheet, data, timestamp) {
  sheet.appendRow([
    timestamp,
    data.first_name,
    data.last_name,
    data.email,
    data.brand,
    data.website,
    data.service,
    data.brief,
    CONFIG.DEFAULT_SOURCE,
    CONFIG.DEFAULT_STATUS
  ]);
}

// ── EMAIL: CUSTOMER CONFIRMATION ─────────────────────────────────────

function sendCustomerConfirmationEmail(data) {
  var subject = "We've received your discovery call request | NRC";
  var plainBody = buildCustomerPlainText(data);
  var htmlBody = buildCustomerHtml(data);

  // CID inline image, not a hosted URL: nrculture.com was found serving a
  // stale build with no working asset path when this was last checked, and
  // Vite content-hashes the logo's filename on every rebuild anyway, so a
  // hosted URL isn't a stable target. Embedding the bytes directly means
  // the logo can never break due to hosting/deploy state.
  var logoBlob = Utilities.newBlob(Utilities.base64Decode(EMAIL_LOGO_BASE64), 'image/png', 'nrc-logo.png');

  GmailApp.sendEmail(data.email, subject, plainBody, {
    htmlBody: htmlBody,
    name: CONFIG.SENDER_DISPLAY_NAME,
    replyTo: CONFIG.INTERNAL_NOTIFY_EMAIL,
    inlineImages: { logo: logoBlob }
  });
}

