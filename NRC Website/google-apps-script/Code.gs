// ── EMAIL: INTERNAL NOTIFICATION ─────────────────────────────────────

function sendInternalNotificationEmail(data, timestamp) {
  var subject = 'New NRC Discovery Call Request — ' + data.brand;
  var sheetLink = 'https://docs.google.com/spreadsheets/d/' + CONFIG.SPREADSHEET_ID + '/edit';

  var plainBody = [
    'New discovery call request received.',
    '',
    'Submitted At: ' + timestamp + ' (' + CONFIG.TIMEZONE + ')',
    'First Name: ' + data.first_name,
    'Last Name: ' + data.last_name,
    'Email Address: ' + data.email,
    'Brand / Company: ' + data.brand,
    'Website or Instagram: ' + (data.website || '(not provided)'),
    'Service Interested In: ' + data.service,
    'Tell Us About Your Brand: ' + data.brief,
    'Source: ' + CONFIG.DEFAULT_SOURCE,
    '',
    'Google Sheet: ' + sheetLink
  ].join('\n');

  var htmlBody = '' +
'<div style="font-family:Helvetica,Arial,sans-serif;font-size:14px;color:#2A2420;max-width:600px;">' +
  '<h2 style="font-family:Georgia,serif;font-size:18px;color:#2A2420;margin:0 0 16px 0;">New Discovery Call Request</h2>' +
  '<table role="presentation" cellpadding="6" cellspacing="0" style="border-collapse:collapse;width:100%;">' +
    emailRow('Submitted At', escapeHtml(timestamp) + ' (' + CONFIG.TIMEZONE + ')') +
    emailRow('First Name', escapeHtml(data.first_name)) +
    emailRow('Last Name', escapeHtml(data.last_name)) +
    emailRow('Email Address', escapeHtml(data.email)) +
    emailRow('Brand / Company', escapeHtml(data.brand)) +
    emailRow('Website or Instagram', escapeHtml(data.website || '(not provided)')) +
    emailRow('Service Interested In', escapeHtml(data.service)) +
    emailRow('Tell Us About Your Brand', escapeHtml(data.brief).replace(/\n/g, '<br>')) +
    emailRow('Source', escapeHtml(CONFIG.DEFAULT_SOURCE)) +
  '</table>' +
  '<p style="margin-top:20px;"><a href="' + sheetLink + '" style="color:#B89780;">Open in Google Sheet</a></p>' +
'</div>';

  GmailApp.sendEmail(CONFIG.INTERNAL_NOTIFY_EMAIL, subject, plainBody, {
    htmlBody: htmlBody,
    name: CONFIG.SENDER_DISPLAY_NAME
  });
}

function emailRow(label, value) {
  return '<tr>' +
    '<td style="border:1px solid #EDE7DB;background-color:#F5F0E8;font-weight:600;vertical-align:top;white-space:nowrap;">' + label + '</td>' +
    '<td style="border:1px solid #EDE7DB;">' + value + '</td>' +
    '</tr>';
}

// ── RESPONSE HELPER ──────────────────────────────────────────────────

function jsonResponse(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);
}
