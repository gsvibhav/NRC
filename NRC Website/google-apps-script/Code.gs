        '<a href="https://www.instagram.com/nextreachculture/" style="color:#B89780;text-decoration:none;">Instagram</a><br>' +
        '<a href="https://wa.me/919347209987" style="color:#B89780;text-decoration:none;">WhatsApp</a>' +
