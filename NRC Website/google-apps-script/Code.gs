    '',
    "We've received your discovery call request for " + data.brand + '. Our team will review the details you shared and get back to you within 48 hours.',
    '',
    'You can also reach us through:',
    '',
    'Website: https://nrculture.com/',
    'Instagram: https://www.instagram.com/nextreachculture/',
    'WhatsApp: https://wa.me/919347209987',
    '',
    'Content that connects. Culture that converts.',
    '',
    'Warm regards,',
    'Team NRC'
  ].join('\n');
}

