      '<tr><td style="padding:16px 40px 0 40px;font-family:Helvetica,Arial,sans-serif;font-size:15px;line-height:1.6;color:#2A2420;">' +
        "We&rsquo;ve received your discovery call request for <strong>" + brand + '</strong>. Our team will review the details you shared and get back to you within 48 hours.' +
      '</td></tr>' +

      '<tr><td style="padding:28px 40px 0 40px;font-family:Helvetica,Arial,sans-serif;font-size:13px;line-height:2;color:#2A2420;">' +
        'You can also reach us through:' +
      '</td></tr>' +
      '<tr><td style="padding:8px 40px 0 40px;font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:2;">' +
